# Copy this file to .env and fill in real values. Never commit your .env.

PORT=3000
NODE_ENV=development

# Allowed CORS origin. "*" is fine for local development. In production set this
# to your deployed origin (e.g. https://your-app.up.railway.app).
ALLOWED_ORIGIN=*

# ── Authentication (email magic-link) ────────────────────────────────────────
# Hosting a room can require a signed-in account; joining never does. Sign-in is
# passwordless: users get a one-time link by email. Full setup guide: docs/AUTH_SETUP.md
#
# Whether hosting REQUIRES sign-in:
#   unset (default) → required only once an email provider is configured (so while
#                     you're still setting email up, hosting stays OPEN and the rest
#                     of the app is fully usable).
#   true            → always require sign-in to host.
#   false           → never require sign-in (open hosting).
# REQUIRE_HOST_AUTH=true
#
# Public base URL used to build the magic-link (defaults to the request host,
# which is correct behind Railway's proxy). Set explicitly if you front the app
# with a custom domain.
# PUBLIC_BASE_URL=https://your-app.up.railway.app
#
# Email provider — pick ONE (Resend API is preferred; SMTP is the fallback).
#
# Option A — Resend HTTP API (recommended: one key, no SMTP, no extra deps).
#   Get a key at https://resend.com → API Keys. The "from" must be a verified
#   domain sender, or use onboarding@resend.dev (test sender — only delivers to
#   the email that owns your Resend account).
# RESEND_API_KEY=re_your_api_key_here
# MAIL_FROM=WordWars <onboarding@resend.dev>
#
# Option B — SMTP via nodemailer (any provider: Resend SMTP, SendGrid, Mailgun,
#   Postmark, Gmail SMTP, etc.). Used only when RESEND_API_KEY is not set.
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false                 # true for port 465
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# SMTP_FROM=WordWars <no-reply@yourdomain.com>

# Merriam-Webster Collegiate API key (word validation + definitions).
# Get a free key at: https://dictionaryapi.com/register/index
MW_API_KEY=your_merriam_webster_key_here

# Optional: Redis connection string. When set, active game state is snapshotted
# to Redis and restored on boot, so games survive a redeploy/restart. Leave unset
# for local dev (state stays in-memory). On Railway: add a Redis service and use
# its provided REDIS_URL (e.g. redis://default:password@host:6379).
# REDIS_URL=redis://localhost:6379
